# wiseflow-client daemon.env 模板
#
# entrypoint 运行期把占位渲染成真实值（从 docker run -e 或 -e FILE 读）。
# 用户必填：AWK_API_KEY、OFB_KEY。其余可选或默认。

# ── 必填 ─────────────────────────────────────────────────────────────────────
# AWK_API_KEY：用户自带的火山引擎 key（覆盖语言/视觉/生图，D13 纯客户端）
AWK_API_KEY=__FILL_AWK_API_KEY__
# OFB_KEY：产品方发放的中转服务凭证（X-OFB-Key header）
OFB_KEY=__FILL_OFB_KEY__

# ── relay 端点（默认固定，用户无需改） ─────────────────────────────────────
RELAY_BASE_URL=https://relay.wiseflow.example.com

# ── 可选 ─────────────────────────────────────────────────────────────────────
# SMTP（邮件技能用，不配则邮件技能禁用）
# SMTP_HOST=
# SMTP_PORT=465
# SMTP_USER=
# SMTP_PASS=

# ── 由 entrypoint 注入，用户不用配 ─────────────────────────────────────────
# 以下 relay 子端点由 RELAY_BASE_URL 派生，entrypoint 写入各 skill 配置：
#   WENYAN_SERVER_URL = $RELAY_BASE_URL/api/v1/wx-mp
#   WXWORK_PROXY_URL  = $RELAY_BASE_URL/api/v1/wxwork
#   SIGN_URL          = $RELAY_BASE_URL/api/v1/sign
#   PUBLISH_RELAY_URL = $RELAY_BASE_URL/api/v1/publish
#   VIDEO_RELAY_URL   = $RELAY_BASE_URL/api/v1/video
#   AWADA_URL         = $RELAY_BASE_URL/api/v1/awada（sales-cs 启用时）

# ── awada（默认禁用，D10；启用由 IT engineer 操作） ────────────────────────
AWADA_ENABLED=false
